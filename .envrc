#!/usr/bin/env bash

export DIRENV_WARN_TIMEOUT=20s

eval "$(devenv direnvrc)"

# Decrypt sops-managed secrets into .env (dotenv loads it). .env.sops is the
# committed source of truth; .env is the gitignored decrypted working copy.
if [ -f .env.sops ] && [ ! -f .env ]; then
  sops -d --input-type dotenv --output-type dotenv .env.sops > .env
fi

# `use devenv` supports the same options as the `devenv shell` command.
use devenv
