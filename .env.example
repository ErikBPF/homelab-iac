# Per-environment UniFi API keys.
# Terragrunt reads UNIFI_API_KEY_<env> and passes it to the provider as an
# input (TF_VAR_*), so the secret stays in the shell env — never on disk, never
# in git. The non-secret api_url lives in unifi/environments/<env>/env.hcl.
#
# Generate a key: UniFi -> Settings -> Control Plane -> Integrations ->
#   Create API Key  (requires Network app >= 9.0.108).
#
# Copy this file to .env (gitignored) and fill real values.

UNIFI_API_KEY_home=<HOME_UDM_API_KEY>
UNIFI_API_KEY_lab=<LAB_CONTROLLER_API_KEY>
UNIFI_WLAN_PSK_QUE=<SSID_QUE_WIFI_PSK>
UNIFI_WLAN_PSK_ERRADO=<SSID_WIFI_ERRADO_PSK>
UNIFI_WLAN_PSK_FAST=<SSID_FAST_PSK>

UNIFI_STATE_PASSPHRASE=<32+ char passphrase, back it up>

# Tailscale OAuth client (admin console -> Settings -> OAuth clients; scopes: acl, dns)
TAILSCALE_OAUTH_CLIENT_ID=<TS_OAUTH_CLIENT_ID>
TAILSCALE_OAUTH_CLIENT_SECRET=<TS_OAUTH_CLIENT_SECRET>
TAILSCALE_TAILNET=-

# Cloudflare BOOTSTRAP token — the single manual root of the declarative chain
# (RFC 2026-06-28 cloudflare-token-terraform-migration). It both authenticates
# the provider for the resources this repo applies directly AND can mint the
# per-consumer cloudflare_api_token resources. Scopes:
#   User:API Tokens:Edit                             [mint/manage tokens]
#   Zone:DNS:Edit + Zone:Read (pastelariadev.com)    [dns unit]
#   Account:Cloudflare Tunnel:Edit                   [tunnel unit]
# Prefer a scoped token over the account Global API Key (revocable, auditable).
CLOUDFLARE_API_TOKEN=<CF_BOOTSTRAP_API_TOKEN>

# Tunnel connector secret (write-only) — only needed to ROTATE a tunnel's
# CLOUDFLARE_TUNNEL_TOKEN. Leave unset to import/keep the existing tunnel; set a
# fresh `openssl rand -base64 32` value, apply, then re-bridge the new token.
CF_TUNNEL_SECRET_HOMEASSISTANT_REMOTE_ACCESS=

# Oracle Cloud (OCI) — API signing key. Console -> Profile -> My profile ->
# API keys -> Add API key -> Generate -> Download private key. The config
# preview shown after adding gives tenancy/user/fingerprint/region.
OCI_tenancy_ocid=<ocid1.tenancy.oc1..>
OCI_user_ocid=<ocid1.user.oc1..>
OCI_fingerprint=<aa:bb:cc:..>
# Private key PEM, base64-encoded single-line: base64 -w0 your-key.pem
OCI_private_key_b64=<base64 of the .pem>
OCI_region=<e.g. sa-saopaulo-1>
# Compartment to create everything in (VCN/subnet/gateway/instance are all
# made by this project — clean slate). Root compartment OCID = tenancy OCID.
OCI_compartment_ocid=<ocid1.compartment.oc1..>
# Optional: pin an AD if A1 capacity is exhausted in the default one.
OCI_availability_domain=
# Optional: override the SSH pubkey injected for the ubuntu user
# (default ~/.ssh/id_ed25519.pub).
OCI_SSH_PUBKEY_FILE=

# GitHub — the `github/` component (integrations/github provider) manages repo
# settings + Actions/workflow-token permissions for the flake-input repos
# (codex-flake, opencode-flake, hermes-flake). The provider reads GITHUB_TOKEN
# + GITHUB_OWNER from the shell. Token needs, per repo: Administration
# (read/write) + Actions (read/write); a classic PAT `repo` scope covers it.
# Fine-grained PAT: Repository access = those repos, perms Administration:RW,
# Actions:RW, Contents:RO, Metadata:RO.
GITHUB_OWNER=ErikBPF
GITHUB_TOKEN=<GITHUB_PAT>

# Narrow Kindle release App. Creation is a one-time GitHub bootstrap because
# integrations/github cannot create Apps; after that, IaC owns the Servarr
# installation attachment and the two kindle-dash Actions secrets. App
# permissions: Contents RW, Pull requests RW, Checks RO, Commit statuses RO,
# Metadata RO. Encode the downloaded PEM as one line: base64 -w0 key.pem
KINDLE_RELEASE_APP_ID=
KINDLE_RELEASE_INSTALLATION_ID=
KINDLE_RELEASE_PRIVATE_KEY_B64=
KINDLE_RELEASE_CLIENT_ID=
KINDLE_RELEASE_CLIENT_SECRET=
GITHUB_APP_MANAGEMENT_TOKEN=
GITHUB_APP_MANAGEMENT_REFRESH_TOKEN=

# Scoped OpenBao AppRole for the Terraform-managed HA harness LiteLLM key.
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# NetBird — the `netbird/` component (netbirdio/netbird) manages the overlay
# admin: setup keys, groups, default-deny policy, split-DNS, routes. The provider
# reads NETBIRD_MANAGEMENT_URL + NETBIRD_TOKEN from the shell. Mint the PAT
# (human, one-time) via the mgmt REST API using a `netbird` CLI OIDC token —
# POST https://nb.homelab.pastelariadev.com/api/users/{userId}/tokens — because
# the netbird dashboard SSO is deferred (upstream bug); the API works. The
# endpoint is tailnet-only: apply from a wired LAN host joined to the tailnet.
NETBIRD_MANAGEMENT_URL=https://nb.homelab.pastelariadev.com
NETBIRD_TOKEN=<netbird PAT>

# PocketID — the `pocketid/` component (Trozz/pocketid) manages the NetBird OIDC
# client. The provider reads POCKETID_BASE_URL + POCKETID_API_TOKEN. Mint the API
# token in the PocketID admin UI (id.<zone>, passkey works) -> Settings -> API
# Keys. Tailnet-only: apply from a wired LAN host joined to the tailnet.
POCKETID_BASE_URL=https://id.homelab.pastelariadev.com
POCKETID_API_TOKEN=<pocketid API token>
