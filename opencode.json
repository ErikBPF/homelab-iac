{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": {
      "*": "ask",
      "unifi/**": "allow",
      "*.tfvars": "ask",
      "*.sops": "deny",
      "*.env*": "deny",
      "**/.state": "deny",
      "*.age": "deny"
    },
    "bash": {
      "*": "ask",
      "terragrunt *": "ask",
      "tofu *": "ask",
      "just plan-global": "allow",
      "just plan *": "allow",
      "just plan-global *": "allow",
      "just apply-global": "ask",
      "just apply-global *": "ask",
      "just apply *": "ask",
      "git *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "tf *": "ask",
      "rm -rf /*": "deny",
      "rm -rf ~*": "deny",
      "ssh *": "ask"
    }
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "bun", "x", "@modelcontextprotocol/server-filesystem",
        "/home/erik/Documents/erik/homelab-iac"
      ],
      "enabled": true
    }
  }
}