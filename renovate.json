{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "dockerfile",
    "github-actions",
    "terraform"
  ],
  "automerge": false,
  "packageRules": [
    {
      "description": "Infrastructure dependencies always require review",
      "matchManagers": [
        "dockerfile",
        "github-actions",
        "terraform"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "infrastructure"
      ]
    }
  ]
}
