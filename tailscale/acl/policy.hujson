{
	// Named tailnet/LAN addresses (stable Tailscale IPs; swag = a LAN IP on
	// discovery's advertised subnet, where *.homelab.pastelariadev.com resolves).
	"hosts": {
		"laptop":     "100.74.137.124",
		"pathfinder": "100.104.92.5",
		"galaxy":     "100.66.253.15",
		"discovery":  "100.76.140.121",
		"swag":       "192.168.10.210",
		"kepler":     "100.94.239.46",
		"orion":      "100.102.11.127",
		"archinaut":  "100.67.123.113",
	},

	// Auto-approve discovery's advertised routes (the node is owned by this
	// account), so they take effect on apply without a manual approval click.
	// Narrowed from 192.168.10.0/24 to /32s: a broad subnet route poisons
	// on-LAN hosts that also run --accept-routes (orion/kepler) — they pull
	// their own subnet into Tailscale's table 52 and blackhole the LAN. Only
	// the LAN-only devices that genuinely need tailnet reach are approved:
	// swag ingress (.210), UDM (.1), swOS switch (.2).
	"autoApprovers": {
		"routes": {
			"192.168.10.210/32": ["erikbogado@gmail.com"],
			"192.168.10.1/32":   ["erikbogado@gmail.com"],
			"192.168.10.2/32":   ["erikbogado@gmail.com"],
		},
	},

	// Tag ownership. tag:server lets the fleet enroll via a non-expiring OAuth
	// client secret (scope auth_keys, tag:server) instead of a 90-day auth key —
	// a device advertising tag:server is owned by the tag, and the account owns
	// the tag here so it can mint/rotate keys for it. Applied first for voyager.
	"tagOwners": {
		"tag:server": ["erikbogado@gmail.com"],
	},

	"acls": [
		// 1. Admin devices: OpenSSH (port 2222) into everything.
		{"action": "accept", "src": ["laptop", "pathfinder", "galaxy"], "dst": ["*:2222"]},

		// 2. Everyone: DNS to discovery (MagicDNS nameserver / AdGuard).
		{"action": "accept", "src": ["*"], "dst": ["discovery:53", "swag:53"]},

		// 3. Everyone: the SWAG ingress only. All services are published as
		//    *.homelab.pastelariadev.com -> swag, which reverse-proxies them.
		{"action": "accept", "src": ["*"], "dst": ["swag:80,443"]},

		// 4. discovery is the hub (SWAG reverse-proxy, LiteLLM router, monitoring,
		//    DNS) — it reaches every host on every port.
		{"action": "accept", "src": ["discovery"], "dst": ["*:*"]},

		// 5. Preserved: Syncthing between fleet hosts.
		{
			"action": "accept",
			"src":    ["laptop", "pathfinder", "kepler", "orion", "discovery"],
			"dst":    ["laptop:22000", "pathfinder:22000", "kepler:22000", "orion:22000", "discovery:22000"],
		},

		// 6. Preserved: NFS / SMB to the kepler NAS from fleet hosts.
		{
			"action": "accept",
			"src":    ["laptop", "pathfinder", "orion", "discovery"],
			"dst":    ["kepler:111,445,2049,4000,4001,4002"],
		},

		// 7. Fleet Alloy -> discovery's observability sinks: Loki :3100 (logs) +
		//    Prometheus remote_write :9090 (metrics). Every host's Alloy pushes
		//    here; k3s in-cluster Alloy egresses SNAT'd to kepler's TS IP too.
		//    archinaut ships journal logs via vector (lite alloy; the 1 GB Pi
		//    can't run full alloy) — logs-only, but the bundled :9090 grant is
		//    harmless.
		{"action": "accept", "src": ["laptop", "pathfinder", "orion", "kepler", "archinaut"], "dst": ["discovery:3100,9090"]},

		// 8. Admin devices reach the whole LAN through discovery's subnet route,
		//    so tailnet devices can hit LAN-only hosts (swOS switches, UDM,
		//    printer, IoT) that can't run Tailscale. Admin-only preserves the
		//    posture — other tailnet devices still get only SWAG (rule 3). SNAT
		//    on the router means no return route is needed on the UDM.
		{"action": "accept", "src": ["laptop", "pathfinder", "galaxy"], "dst": ["192.168.10.0/24:*"]},

		// 9. Fleet pulls from orion's nix binary cache (nix-serve :5000) over
		//    MagicDNS (http://orion:5000, see desktop-nixos common.nix). The LAN
		//    path works via rule 8's subnet route, but non-admin hosts and the
		//    MagicDNS name need this explicit grant or the substituter times out.
		{"action": "accept", "src": ["laptop", "pathfinder", "kepler"], "dst": ["orion:5000"]},

		// 10. Lab ESO (kepler) -> the platform OpenBao on discovery :8200 (P3.1b).
		//    External Secrets in the kepler lab cluster repoints off the disposable
		//    in-cluster vault to the always-on OpenBao on discovery. In-cluster ESO
		//    pods egress SNAT'd to kepler's tailnet IP, so src "kepler" covers them
		//    (same path rule 7's in-cluster Alloy uses). Blast radius = lab only.
		{"action": "accept", "src": ["kepler"], "dst": ["discovery:8200"]},

		// 11. Any fleet host -> orion's shared sccache WebDAV cache (:4321, nginx
		//    dav). Routes dev-loop `cargo build` artifacts to orion; a miss or an
		//    unreachable orion falls back to a local compile (desktop-nixos
		//    modules/services/sccache.nix). Broad src so servers can share the
		//    cache too; actual use is opt-in per host (sccacheClient.enable).
		{"action": "accept", "src": ["*"], "dst": ["orion:4321"]},
	],

	// Hosts use OpenSSH on :2222 (governed by the acls above); Tailscale SSH is
	// not enabled, so no "ssh" section. Add one (needs tags) if you ever turn on
	// `tailscale up --ssh`.

	"tests": [
		{"src": "laptop", "accept": ["kepler:2222"]},    // admin can SSH
		{"src": "orion", "deny": ["kepler:2222"]},       // non-admin cannot SSH
		{"src": "galaxy", "accept": ["swag:443"]},       // anyone reaches SWAG
		{"src": "orion", "deny": ["kepler:8001"]},       // no direct backend access
		{"src": "discovery", "accept": ["kepler:6443"]}, // hub reaches k3s
		{"src": "discovery", "accept": ["orion:8080"]},  // hub reaches host services (LLMs)
		{"src": "kepler", "accept": ["discovery:3100"]}, // cluster ships logs to Loki
		{"src": "kepler", "accept": ["discovery:8200"]}, // lab ESO reads OpenBao
		{"src": "orion", "accept": ["discovery:9090"]},  // host Alloy ships metrics
		{"src": "orion", "accept": ["kepler:2049"]},     // NFS preserved
		{"src": "kepler", "accept": ["orion:22000"]},    // syncthing preserved
		{"src": "kepler", "accept": ["orion:5000"]},     // fleet pulls orion nix cache
		{"src": "laptop", "accept": ["orion:4321"]},     // workstation reaches sccache cache
		{"src": "kepler", "accept": ["orion:4321"]},     // servers may share the sccache cache too
		{"src": "galaxy", "deny": ["kepler:2049"]},      // phone not an NFS client
		{"src": "galaxy", "accept": ["192.168.10.2:80"]},  // admin phone reaches a LAN-only switch UI
		{"src": "laptop", "accept": ["192.168.10.1:443"]}, // admin reaches the UDM via the route
		{"src": "orion", "deny": ["192.168.10.2:80"]},     // non-admin can't reach LAN-only hosts
	],
}
